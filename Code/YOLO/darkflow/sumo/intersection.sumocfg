<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <input>
    <net-file value="intersection.net.xml"/>
    <route-files value="empty.rou.xml"/>
  </input>

  <time>
    <begin value="0"/>
    <end value="2000"/>
    <step-length value="1"/>
  </time>

  <processing>
    <ignore-route-errors value="true"/>
  </processing>

  <report>
    <no-step-log value="true"/>
    <verbose value="false"/>
  </report>
</configuration>
